<!DOCTYPE html>
<html>
<head>
    <title>Text Styling App</title>

    <style>
        .bold {
            font-weight: bold;
        }
        .italic {
            font-style: italic;
        }
        .smallcaps {
            font-variant: small-caps;
        }
    </style>

</head>
<body>

    <!-- Required lines at start -->
    <p>s.suraj</p>
    <p>24BCE0346</p>

<h2>Text Styling Application</h2>

<fieldset>
    <legend>Choose Style</legend>

    <button onclick="applyStyle('bold')">Bold</button>
    <button onclick="applyStyle('italic')">Italic</button>
    <button onclick="applyStyle('smallcaps')">Small Caps</button>
    <button onclick="applyStyle('bold italic')">Bold + Italic</button>
    <button onclick="clearStyle()">Clear</button>
</fieldset>

<br>

<p id="text">This is a sample message</p>

<script>
function applyStyle(style) {
    document.getElementById("text").className = style;
}

function clearStyle() {
    document.getElementById("text").className = "";
}
</script>

</body>
</html>
